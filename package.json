{
  "name": "proud-flow",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "type": "module",
  "scripts": {
    "dev": "node scripts/turbo-run.mjs dev",
    "dev:web": "pnpm --filter @proud-flow/web dev",
    "dev:api": "pnpm --filter @proud-flow/api dev",
    "dev:cli": "pnpm --filter @proud-flow/cli dev",
    "build": "node scripts/turbo-run.mjs build",
    "typecheck": "pnpm build && node scripts/turbo-run.mjs typecheck",
    "lint": "node scripts/lint.mjs",
    "test": "pnpm build && node scripts/turbo-run.mjs test",
    "test:coverage": "pnpm build && node scripts/turbo-run.mjs test:coverage",
    "test:e2e": "node apps/cli/scripts/bundle-skills.mjs && pnpm exec vitest run -c vitest.e2e.config.ts --passWithNoTests",
    "test:browser": "pnpm exec playwright test",
    "release:check": "node scripts/check-release-readiness.mjs",
    "deploy:api:dev": "pnpm --filter @proud-flow/api deploy:dev",
    "deploy:api:prod": "pnpm --filter @proud-flow/api deploy:prod",
    "deploy:web:dev": "pnpm --filter @proud-flow/web deploy:dev",
    "deploy:web:prod": "pnpm --filter @proud-flow/web deploy:prod",
    "db:migrate:dev": "pnpm --filter @proud-flow/api db:migrate:dev",
    "db:migrate:prod": "pnpm --filter @proud-flow/api db:migrate:prod",
    "publish:cli": "pnpm --filter @proud-flow/cli publish:package",
    "format": "node scripts/format.mjs --write",
    "format:check": "node scripts/format.mjs --check",
    "openapi:generate": "pnpm --filter @proud-flow/api-contract openapi:generate"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.8",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "wrangler": "^4.98.0"
  }
}
