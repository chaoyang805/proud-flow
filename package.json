{
  "name": "proud-flow",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "type": "module",
  "scripts": {
    "dev": "node scripts/turbo-run.mjs dev",
    "dev:web": "pnpm --filter @proud-flow/web dev",
    "dev:api": "pnpm --filter @proud-flow/api dev",
    "dev:cli": "pnpm --filter @proud-flow/cli dev",
    "build": "node scripts/turbo-run.mjs build",
    "typecheck": "pnpm build && node scripts/turbo-run.mjs typecheck",
    "lint": "node scripts/lint.mjs",
    "test": "pnpm build && node scripts/turbo-run.mjs test",
    "test:coverage": "pnpm build && node scripts/turbo-run.mjs test:coverage",
    "test:e2e": "pnpm skills:package && pnpm exec vitest run -c vitest.e2e.config.ts --passWithNoTests",
    "skills:package": "node scripts/build-skill-packages.mjs",
    "format": "node scripts/format.mjs --write",
    "format:check": "node scripts/format.mjs --check",
    "openapi:generate": "pnpm --filter @proud-flow/api-contract openapi:generate"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.8",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
