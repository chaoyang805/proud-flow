{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "types": [
      "node",
      "@cloudflare/workers-types"
    ],
    "paths": {
      "cloudflare:workers": [
        "./tests/mocks/cloudflare-workers.ts"
      ]
    },
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler"
  },
  "include": [
    "src/**/*.ts",
    "tests/unit/**/*.test.ts"
  ]
}
