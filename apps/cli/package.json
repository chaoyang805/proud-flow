{
  "name": "@proud-flow/cli",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Proud Flow local CLI workspace placeholder",
  "bin": {
    "proud-flow": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json --resolve-full-paths --resolve-full-extension .js",
    "publish:package": "pnpm build && pnpm pack --pack-destination ../../dist/releases",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "lint": "node ../../scripts/lint-workspace.mjs",
    "test": "node ../../scripts/run-workspace-tests.mjs",
    "test:coverage": "node ../../scripts/run-workspace-coverage.mjs"
  },
  "devDependencies": {
    "@proud-flow/config": "workspace:*"
  },
  "dependencies": {
    "@proud-flow/api-client": "workspace:*",
    "@proud-flow/api-contract": "workspace:*",
    "@proud-flow/domain": "workspace:*",
    "pino": "^10.3.1",
    "pino-roll": "^4.0.0"
  }
}
